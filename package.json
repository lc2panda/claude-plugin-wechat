{
  "name": "claude-plugin-wechat",
  "version": "2.1.1",
  "description": "Multi-channel Claude Code plugin — WeChat, Feishu, DingTalk and more",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wechat-acp": "./channels/wechat/acp-bridge.ts",
    "feishu-acp": "./channels/feishu/acp-bridge.ts"
  },
  "scripts": {
    "postinstall": "bun install --no-summary",
    "start:wechat": "bun channels/wechat/server.ts",
    "start:wechat:acp": "bun channels/wechat/acp-bridge.ts",
    "start:feishu": "bun channels/feishu/server.ts",
    "start:feishu:acp": "bun channels/feishu/acp-bridge.ts"
  },
  "keywords": ["wechat", "weixin", "feishu", "lark", "claude", "claude-code", "mcp", "acp", "chatbot", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/lc2panda/claude-plugin-wechat.git"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "silk-wasm": "^3.6.0",
    "zod": "^3.23.0"
  }
}
